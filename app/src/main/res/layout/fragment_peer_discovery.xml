<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingBottom="56dp">

    <!-- Mesh Visualization Area -->
    <com.kitchensync.ui.discovery.PeerMeshView
        android:id="@+id/peer_mesh_view"
        android:layout_width="match_parent"
        android:layout_height="@dimen/peer_mesh_height"
        android:background="@color/surface" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15000000" />

    <!-- Status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm">

        <View
            android:id="@+id/status_indicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_peer_bubble" />

        <TextView
            android:id="@+id/text_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/searching"
            android:textColor="@color/on_surface_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/text_peer_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/syncing_blue"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Peer List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_peers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/spacing_sm" />

</LinearLayout>
