<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.YumKitchenSync" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/yum_red</item>
        <item name="colorPrimaryDark">@color/yum_red_dark</item>
        <item name="colorAccent">@color/yum_amber</item>
        <item name="colorSecondary">@color/yum_amber</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/yum_red_dark</item>
    </style>

    <style name="Theme.YumKitchenSync.NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/yum_red</item>
        <item name="colorPrimaryDark">@color/yum_red_dark</item>
        <item name="colorAccent">@color/yum_amber</item>
        <item name="colorSecondary">@color/yum_amber</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/yum_red_dark</item>
    </style>

    <style name="RoleCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">6dp</item>
        <item name="contentPadding">@dimen/spacing_lg</item>
    </style>

    <style name="OrderCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">3dp</item>
    </style>

    <style name="StatusChip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipMinHeight">24dp</item>
        <item name="android:textSize">11sp</item>
        <item name="textEndPadding">8dp</item>
        <item name="textStartPadding">8dp</item>
    </style>
</resources>
